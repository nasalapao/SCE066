    0 AS DIFF_DAT1,
   0 AS DIFF_DAT2,
   0 AS DIFF_DAT3,
   0 AS DIFF_DAT4,
   0 AS DIFF_DAT5    from itprod.shdoch
    left join mvxcdtprod.dconsi on dacono = shcono and daconn = shivno
  )    data
  left join (select distinct uacono,uadivi,uaconn,uatepy,uatedl from mvxcdtprod.odhead) odhead on uacono = shcono and uadivi = shdivi and uaconn = shivno
  left join mvxcdtprod.csytab csytab_tepy on csytab_tepy.ctcono = shcono and csytab_tepy.ctstco = 'TEPY' and csytab_tepy.ctstky = uatepy
  left join mvxcdtprod.csytab csytab_tedl on csytab_tedl.ctcono = shcono and csytab_tedl.ctstco = 'TEDL' and csytab_tedl.ctstky = uatedl
     where shetdd &gt;= 20190901 and shetdd &lt;= 20190930
     and shivno = '1903197'
   and diff_dat1 &lt; 0 or diff_dat2 &lt; 0 or diff_dat3 &lt; 0 or diff_dat4 &lt; 0 or diff_dat5 &lt; 0  and  shusid LIKE '%'</CommandText>
