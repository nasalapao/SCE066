                    <CommandText>select shusid,'' oaorst,shcuno,shivno,shetdd,shetad,'' okcunm,'' drtx40,dacdld,diff_dat1,diff_dat2,diff_dat3,diff_dat4,diff_dat5,0 diff_dat6,0 diff_dat7,'' shstatus,'' slremk,
csytab_tepy.cttx15 as payterm,UATEDL As DeliTerm
from    (
   select shcono,shdivi,shusid,shivno,shcuno,shetdd,shetad,dacdld,shdat1,shdat2,shdat3,shdat4,shdat5,
    0 as deadlinedate,
